{
  "name": "@ivorycanvas/codeward",
  "version": "0.2.0",
  "description": "Local-first QA skill that turns PR diffs into affected flows, missing evidence, and E2E drafts with no cloud or LLM token.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "bin": {
    "codeward": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "skills",
    "schema",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "test": "pnpm build && node --test test/*.test.mjs",
    "coverage": "pnpm build && node --test --experimental-test-coverage --test-coverage-include=\"dist/**/*.js\" --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 test/*.test.mjs",
    "scan": "pnpm build && node dist/cli.js scan .",
    "report": "pnpm build && node dist/cli.js report . --output CODEWARD_REPORT.md",
    "release:check": "pnpm test && pnpm scan && git diff --check && pnpm run coverage && pnpm pack --dry-run"
  },
  "keywords": [
    "ai",
    "agents",
    "coding-agents",
    "agent-skill",
    "agent-readiness",
    "ai-security",
    "local-first",
    "mcp",
    "preflight",
    "pull-request",
    "e2e",
    "e2e-testing",
    "qa",
    "qa-automation",
    "test-planning",
    "test-generation",
    "verification-manifest",
    "verification-loop",
    "test-manifest",
    "playwright",
    "maestro",
    "repository-security",
    "security",
    "developer-tools",
    "github-actions",
    "guardrails"
  ],
  "author": "IvoryCanvas",
  "license": "MIT",
  "homepage": "https://github.com/IvoryCanvas/codeward#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvoryCanvas/codeward.git"
  },
  "bugs": {
    "url": "https://github.com/IvoryCanvas/codeward/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
