        "maxGenericTitles": 0,
        "minTryableDrafts": 1,
        "maxSelfCheckFail": 0,
        "maxReviewOnlyFiles": 0,
        "maxTodos": 0,
        "maxExecutionBlockers": 2,
        "maxAgentBytes": 4096
      }
    },
