{
  "$comment": "Copy to bench.config.local.json (gitignored) and point targets at real repositories with pinned commits. Project code is read but never executed.",
  "targets": [
    {
      "name": "example-web-app",
      "path": "~/Desktop/example-web-app",
      "base": "<base-sha>",
      "head": "<head-sha>",
      "expect": {
        "runner": "playwright",
        "mustReachFiles": ["app/checkout/page.tsx"],
        "mustNameFlows": ["checkout"],
        "mustDraftFiles": ["checkout"],
        "mustFindSelectors": ["apply-coupon"],
        "mustFindSuccessSignals": ["Discount applied"],
        "maxBlankActions": 0,
        "maxGenericTitles": 0,
        "maxAgentBytes": 4096
      }
    },
    {
      "name": "example-mobile-app",
      "path": "~/Desktop/example-mobile-app",
      "base": "<base-sha>",
      "head": "<head-sha>",
      "expect": {
        "runner": "maestro"
      }
    }
  ]
}
